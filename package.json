{
  "name": "steamblock-link",
  "version": "0.1.0",
  "description": "STEAMBLOCK Studio Link — companion local para el IDE web. Servicio WebSocket que permite compilar y subir a placas Arduino desde el navegador.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "steamblock-link": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "pkg": "pkg dist/index.js --target node22-linux-x64,node22-win-x64 --output dist/steamblock-link",
    "dist": "npm run build && npm run pkg"
  },
  "dependencies": {
    "serialport": "^13.0.0",
    "valibot": "^1.4.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@yao-pkg/pkg": "^6.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "pkg": {
    "assets": [
      "resources/**/*"
    ],
    "targets": [
      "node22-linux-x64",
      "node22-win-x64"
    ],
    "outputPath": "dist"
  },
  "allowScripts": {
    "@serialport/bindings-cpp@13.0.0": true,
    "esbuild@0.28.1": true
  }
}
